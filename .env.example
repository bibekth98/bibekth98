# ============================================================
# AI Marketing Agent – Environment Variables
# Copy this file to .env and fill in your credentials.
# NEVER commit .env to source control.
# ============================================================

# ── OpenAI ────────────────────────────────────────────────
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_MAX_TOKENS=2048

# ── Google Ads ─────────────────────────────────────────────
GOOGLE_ADS_DEVELOPER_TOKEN=your-developer-token
GOOGLE_ADS_CLIENT_ID=your-oauth2-client-id
GOOGLE_ADS_CLIENT_SECRET=your-oauth2-client-secret
GOOGLE_ADS_REFRESH_TOKEN=your-refresh-token
GOOGLE_ADS_CUSTOMER_ID=your-customer-id-without-dashes
# Monthly budget safety cap (in micros; 50000000 = $50)
GOOGLE_ADS_MONTHLY_BUDGET_CAP_MICROS=50000000

# ── Amazon Associates ──────────────────────────────────────
AMAZON_ACCESS_KEY=your-amazon-access-key
AMAZON_SECRET_KEY=your-amazon-secret-key
AMAZON_PARTNER_TAG=your-partner-tag-20

# ── ShareASale ─────────────────────────────────────────────
SHAREASALE_API_TOKEN=your-token
SHAREASALE_API_SECRET=your-secret
SHAREASALE_AFFILIATE_ID=your-affiliate-id

# ── Commission Junction (CJ) ──────────────────────────────
CJ_API_KEY=your-cj-api-key
CJ_WEBSITE_ID=your-website-id

# ── Agent Behaviour ────────────────────────────────────────
# How often to run the optimisation cycle (seconds). Default: 3600 (1 hour)
AGENT_CYCLE_INTERVAL_SECONDS=3600
# Directory to store JSON/Markdown reports
AGENT_REPORTS_DIR=reports
# Minimum ROAS before pausing / reducing bids
AGENT_MIN_ROAS_THRESHOLD=1.5
# Maximum cost-per-click (USD) before reducing bids
AGENT_MAX_CPC_USD=5.0
# Set to "false" to enable live API writes (default: dry-run)
AGENT_DRY_RUN=true
